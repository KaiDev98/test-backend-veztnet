# ─── Environment untuk Testing ───────────────────────────────────────────────
# Copy file ini menjadi .env.test dan isi dengan nilai yang sesuai
# JANGAN commit file .env.test ke repository!

NODE_ENV=test

# Database Test (gunakan DB terpisah dari development!)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=propshare_test

# JWT
JWT_SECRET=test-secret-key-ganti-ini

# Token untuk testing (generate via endpoint /api/auth/login)
# Jalankan server dev, login sebagai masing-masing role, copy token-nya ke sini
TEST_ADMIN_TOKEN=
TEST_OWNER_TOKEN=
TEST_INVESTOR_TOKEN=
